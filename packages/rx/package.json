{
  "name": "@rx-lang/rx",
  "version": "0.1.0",
  "description": "TypeScript facade for rx readable regex backed by Rust WASM internals",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "repository": "github:erik-kroon/rx",
  "sideEffects": false,
  "files": [
    "dist",
    "wasm-node/package.json",
    "wasm-node/rx_wasm_bg.wasm",
    "wasm-node/rx_wasm_bg.wasm.d.ts",
    "wasm-node/rx_wasm.d.ts",
    "wasm-node/rx_wasm.js",
    "wasm/package.json",
    "wasm/rx_wasm_bg.js",
    "wasm/rx_wasm_bg.wasm",
    "wasm/rx_wasm_bg.wasm.d.ts",
    "wasm/rx_wasm.d.ts",
    "wasm/rx_wasm.js",
    "README.md"
  ],
  "exports": {
    ".": {
      "bun": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js"
      },
      "node": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js"
      },
      "browser": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./builders": {
      "types": "./dist/builders.d.ts",
      "import": "./dist/builders.js"
    }
  },
  "scripts": {
    "build": "pnpm check:deps && pnpm build:wasm && pnpm build:ts",
    "build:ts": "tsup src/index.ts src/node.ts src/builders.ts --format esm --dts",
    "build:wasm": "pnpm build:wasm:browser && pnpm build:wasm:node",
    "build:wasm:browser": "PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build ../../crates/rx-wasm --target bundler --out-dir ../../packages/rx/wasm --out-name rx_wasm",
    "build:wasm:node": "PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build ../../crates/rx-wasm --target nodejs --out-dir ../../packages/rx/wasm-node --out-name rx_wasm",
    "check:deps": "node -e \"try{require.resolve('tsup')}catch{console.error('Missing package dependencies. Run pnpm install in packages/rx before build, pack, or publish.');process.exit(1)}\"",
    "prepack": "pnpm build",
    "smoke:bun": "bun --eval 'import { rx, toRegexSync } from \"@rx-lang/rx\"; console.log(toRegexSync(rx.oneOrMore(rx.oneOf(rx.alphaNumeric(), rx.char(\"/\")))));'",
    "smoke:node": "node --input-type=module --eval 'import { rx, toRegexSync } from \"@rx-lang/rx\"; console.log(toRegexSync(rx.oneOrMore(rx.oneOf(rx.alphaNumeric(), rx.char(\"/\")))));'",
    "test": "pnpm build:wasm && vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
